# --- Python bytecode / caches ---
__pycache__/
*.py[cod]
*$py.class

# --- Packaging / build outputs ---
build/
dist/
*.egg
*.egg-info/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Tooling caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# --- Secrets / local env ---
.env
.env.*

# --- OS cruft ---
.DS_Store
Thumbs.db

# --- Autogram run artifacts ---
# Prompts are regenerated on every run/dump-prompt and are disposable.
# The committed subagent_response_*.json replies are reproducibility inputs and stay tracked.
artifacts/subagent_prompt_*.txt
# Timestamped independent-eval run folders are disposable evaluation outputs.
artifacts/autogram_eval_*/
# Structured run bundles and traces are regenerable learning outputs.
artifacts/**/trace.jsonl
artifacts/**/result.json
